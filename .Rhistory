list_of_vectors <- list(
c(3, 4),
c(1, 2),
c(7, 8),
c(5, 6)
)
# Function to subtract minimum from each column
subtract_col_mins <- function(lst) {
# Get number of columns (assuming all vectors have the same length)
num_cols <- length(lst[[1]])
# Extract columns and compute the minima
columns <- lapply(1:num_cols, function(j) sapply(lst, `[[`, j))
col_mins <- sapply(columns, min)
# Subtract the column minima from each corresponding column value
result <- lapply(lst, function(vec) {
sapply(seq_along(vec), function(j) vec[j] - col_mins[j])
})
return(result)
}
# Apply the function to your list of vectors
adjusted_list <- subtract_col_mins(list_of_vectors)
# Print the result
print(adjusted_list)
